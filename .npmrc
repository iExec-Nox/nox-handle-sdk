ignore-scripts=true # block all lifecycle scripts (postinstall, install, preinstall)
# TODO: re-enable when npm>=11.10.0 is bundled with node LTS
# engine-strict=true # fail if npm version does not satisfy engines field in package.json 
allow-git=none # block git: specifiers in direct and transitive dependencies
min-release-age=3 # reject packages published less than 3 days ago (requires npm>=11.10.0)
