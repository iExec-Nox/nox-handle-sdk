ignore-scripts=true # block all lifecycle scripts (postinstall, install, preinstall)

# for pnpm
minimum-release-age=4320 # reject packages published less than 3 days ago
block-exotic-subdeps=true # block transitive dependencies from using exotic specifiers (git:, file:, etc.)

# for npm
min-release-age=3 # reject packages published less than 3 days ago
allow-git=none # block git: specifiers in direct and transitive dependencies

