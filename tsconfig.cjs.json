{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist/cjs",
    "verbatimModuleSyntax": false,
    "removeComments": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/cjs/.tsbuildinfo",
    "composite": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
