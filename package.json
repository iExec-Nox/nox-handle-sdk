{
  "name": "@iexec-nox/handle",
  "version": "0.1.0-beta.7",
  "description": "TypeScript SDK for NOX Handle",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm && node scripts/postbuild.js && npm run build:doc",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:doc": "rm -rf doc/ && typedoc --tsconfig tsconfig.doc.json",
    "build:watch": "npm run build:cjs:watch & npm run build:esm:watch",
    "build:cjs:watch": "tsc --project tsconfig.cjs.json --watch",
    "build:esm:watch": "tsc --project tsconfig.esm.json --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "format": "prettier --write \"./**/*.ts\"  \"./**/*.json\" \"./**/*.md\"",
    "check-format": "prettier --check \"./**/*.ts\" \"./**/*.json\" \"./**/*.md\"",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iExec-Nox/nox-handle-sdk.git"
  },
  "author": "iExec",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/iExec-Nox/nox-handle-sdk/issues"
  },
  "homepage": "https://github.com/iExec-Nox/nox-handle-sdk#readme",
  "dependencies": {
    "graphql-request": "^7.4.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0",
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "ethers": "^6.16.0",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "viem": "^2.43.5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "npm": ">=11.10.0"
  }
}
