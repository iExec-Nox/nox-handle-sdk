{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/esm",
    "verbatimModuleSyntax": true,
    "removeComments": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/esm/.tsbuildinfo",
    "composite": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
